# AI configuration
GOOGLE_API_KEY=
PROCESS_DELAY=30000

# App configuration
CAMERA_NAME=Bird # fallback device name if an uploaded filename doesn't match the expected pattern
CHECK_INTERVAL=7200000 # 2 hours in milliseconds
DATA_DIR=./data
DOWNLOAD_DIR=./downloads
RETENTION_DAYS=60 # how many days of clips/images to keep

# FTP upload (camera pushes recorded clips here on motion)
UPLOAD_DIR=./uploads
FTP_HOST=0.0.0.0
FTP_PORT=2121
FTP_USERNAME=camera
FTP_PASSWORD=change-me
FTP_PASV_URL=192.168.1.X # LAN IP of this host, required for passive-mode uploads
FTP_PASV_MIN=30100
FTP_PASV_MAX=30110

# BirdNET-Go audio identification (independent of video clips)
BIRDNET_ENABLED=false
BIRDNET_GO_URL=http://192.168.1.X:8080
BIRDNET_MIN_CONFIDENCE=0.7
BIRDNET_LOOKBACK_HOURS=48 # how far back to look for detections on first sync / after downtime
